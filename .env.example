# Copy to .env and fill in. .env is gitignored — nothing here should ever be
# committed with real values. In production set the same keys as Fly secrets
# (see "Deploying to Fly.io" in README.md).
#
# Every key is optional in local development; the defaults below are enough to
# run `npm start` and click around. See the environment-variable table in
# README.md for the full reference.

# --- who's using it ---
# Shared login secret. Leave unset in dev (defaults to "baby"); set a real one
# in production.
# APP_SECRET=
USER_NAMES=Mom,Dad

# --- the baby ---
BABY_NAME=Baby
# App title and home-screen name. Falls back to BABY_NAME.
# APP_NAME=
# YYYY-MM-DD. Enables age display and growth percentiles.
# BIRTH_DATE=
# "boy" or "girl" — picks which WHO growth-standards table to plot against.
# BABY_SEX=

# --- behaviour ---
# Day boundaries used by the reports view.
HOME_TZ=America/Los_Angeles
# Push a nudge after this many quiet hours, then repeat this often.
# NUDGE_HOURS=6
# RENUDGE_MINUTES=60

# --- storage ---
# Where SQLite and photos live. "/data" on Fly.
# DATA_DIR=./data

# --- push notifications ---
# Auto-generated on startup in dev. Generate real ones for production with
# `npx web-push generate-vapid-keys`.
# VAPID_SUBJECT=mailto:you@example.com
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# --- optional integrations ---
# Enables the Claude-generated analysis of diaper photos. Without it, photos
# still upload and display; analysis is simply skipped.
# ANTHROPIC_API_KEY=

# Cookie signing key. Derived from APP_SECRET when unset; set it explicitly if
# you want to rotate APP_SECRET without logging everyone out.
# COOKIE_SECRET=

# Bearer token for POST /api/voice (the Siri Shortcut — see
# docs/siri-voice-logging.md). Deliberately separate from APP_SECRET: it ends up
# baked into Shortcuts that sync and get shared, so it can only create events.
# Leave unset to disable voice logging entirely.
# VOICE_TOKEN=
