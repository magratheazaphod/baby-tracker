# Copy to fly.toml, set your own app name and region, then follow the deploy
# steps in README.md. fly.toml itself is gitignored so the app name stays private.
app = "your-app-name"
primary_region = "ord"

[build]

[env]
  DATA_DIR = "/data"
  HOME_TZ = "America/Chicago"
  NUDGE_HOURS = "6"

[mounts]
  source = "data"
  destination = "/data"

[http_service]
  internal_port = 3000
  force_https = true
  # The nudge timer must keep running, so never let Fly stop the machine.
  auto_stop_machines = "off"
  auto_start_machines = true
  min_machines_running = 1

  # Restarts the machine if the app stops answering or loses its database.
  # Catches a wedged process; it can't tell you when the whole machine or
  # region is down, so pair it with an external monitor (see README).
  [[http_service.checks]]
    grace_period = "10s"
    interval = "30s"
    method = "GET"
    path = "/api/health"
    timeout = "5s"

[[vm]]
  size = "shared-cpu-1x"
  memory = "256mb"
